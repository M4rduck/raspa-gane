generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  /// Premio cada N enlaces emitidos (presorteo secuencial)
  winEvery    Int
  issuedCount Int            @default(0)
  apiKeyHash  String
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  tokens      ScratchToken[]
  prizes      Prize[]
}

model ScratchToken {
  id            String             @id @default(cuid())
  /// Slug público en la URL (/r/[token])
  publicToken   String             @unique
  campaignId    String
  campaign      Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  /// Resultado fijado al emitir el enlace (presorteo)
  isWinner      Boolean
  sequence      Int
  /// Referencia opcional del sistema cliente (ej. id de usuario externo)
  externalRef   String?
  /// Tablero 3x3 serializado en JSON
  boardJson     String?
  /// Índice de línea ganadora (0..2) si aplica
  winningLine   Int?
  /// Premio asignado al tablero ganador (fijado al emitir enlace si hay tabla Prize)
  prizeLabel    String?
  /// Símbolo del tablero 3x3 (PS5, CARRO, …) alineado al premio asignado
  assignedSymbol String?
  prizeId       String?
  prize         Prize?             @relation(fields: [prizeId], references: [id], onDelete: SetNull)
  scratchedAt   DateTime?
  registration  PreRegistration?
  createdAt     DateTime           @default(now())
}

/// Premios por campaña: peso relativo (ej. 1, 10, 50) y stock opcional (null = ilimitado)
model Prize {
  id             String         @id @default(cuid())
  campaignId     String
  campaign       Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  /// Debe coincidir con símbolos del raspable: PS5, CARRO, MOTO, TV, BONO
  symbol         String
  label          String
  /// Peso para el sorteo entre premios elegibles (mismo ratio que porcentajes si solo importan proporciones)
  weight         Int
  /// null = sin tope de unidades
  stockRemaining Int?
  sortOrder      Int            @default(0)
  /// Ruta pública (/prizes/...) o URL https; null = usar imagen por defecto del símbolo en la UI
  imageUrl       String?
  tokens         ScratchToken[]

  @@unique([campaignId, symbol])
}

model PreRegistration {
  id         String       @id @default(cuid())
  tokenId    String       @unique
  token      ScratchToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  fullName   String
  email      String
  phone      String
  documentId String?
  createdAt  DateTime     @default(now())
}
