# PostgreSQL local (crea la base antes: createdb raspa_gane)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/raspa_gane?schema=public"
# URL pública de la app (para construir enlaces en la API)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Clave maestra para crear campañas: header X-Master-Key
MASTER_ADMIN_KEY="cambia-esto-en-produccion"
