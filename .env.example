# PostgreSQL local (crea la base antes: createdb raspa_gane)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/raspa_gane?schema=public"
# AWS / alta concurrencia: URL de RDS Proxy o PgBouncer; limitar conexiones por tarea Node, p. ej.
# ?connection_limit=5&pool_timeout=20  (ajustar al vCPU y al max_connections de RDS)
# URL pública de la app (para construir enlaces en la API)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Clave maestra para crear campañas: header X-Master-Key
MASTER_ADMIN_KEY="cambia-esto-en-produccion"
# HTTPS en prod: Strict-Transport-Security (solo si dominio/subdominios correctos)
# ENABLE_HSTS=true
